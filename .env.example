# OS-APOW Environment Variables Template
# Copy this file to .env and fill in your values

# === Required for All Components ===
# GitHub Personal Access Token with repo and issues scopes
GITHUB_TOKEN=your_github_token_here

# === Required for Sentinel (Orchestrator) ===
# GitHub organization name
GITHUB_ORG=your_org_name

# GitHub repository name
GITHUB_REPO=your_repo_name

# Optional: Bot account login for assign-then-verify locking
# If set, enables distributed locking for multi-sentinel deployments
SENTINEL_BOT_LOGIN=

# === Required for Notifier (Webhook Receiver) ===
# GitHub App webhook secret (used to verify webhook signatures)
WEBHOOK_SECRET=your_webhook_secret_here

# === Optional Configuration ===
# Enable debug logging
DEBUG=false

# Notifier host and port
NOTIFIER_HOST=0.0.0.0
NOTIFIER_PORT=8000

# Sentinel polling interval (seconds)
SENTINEL_POLL_INTERVAL=60

# Sentinel heartbeat interval (seconds)
SENTINEL_HEARTBEAT_INTERVAL=300
